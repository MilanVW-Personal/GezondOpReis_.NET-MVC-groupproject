@using GezondOpReis.ViewModels
@model OnkostEditViewModel

@{
    ViewData["Title"] = "Bewerk Onkost";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="col-md-6">
        <div class="card shadow-lg">
            <div class="card-header bg-primary text-white text-center">
                <h2>Bewerk onkost</h2>
            </div>
            <div class="card-body p-4">
                <form id="account" method="post" asp-action="Edit" asp-route-id="@Model.Id" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                   

                    <div class="form-floating mb-3">
                        <input asp-for="Titel" class="form-control" placeholder="Titel" />
                        <label asp-for="Titel" class="form-label">Titel</label>
                        <span asp-validation-for="Titel" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <textarea asp-for="Omschrijving" class="form-control" placeholder="Beschrijving" rows="3"></textarea>
                        <label asp-for="Omschrijving" class="form-label">Beschrijving</label>
                        <span asp-validation-for="Omschrijving" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Bedrag" class="form-control" placeholder="Bedrag" />
                        <label asp-for="Bedrag" class="form-label">Bedrag</label>
                        <span asp-validation-for="Bedrag" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Datum" class="form-control" type="date" placeholder="Datum" />
                        <label asp-for="Datum" class="form-label">Datum</label>
                        <span asp-validation-for="Datum" class="text-danger"></span>
                    </div>

                    

                    <div class="d-grid gap-2">
                        <button id="register-submit" type="submit" class="btn btn-primary">Wijzig info</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}