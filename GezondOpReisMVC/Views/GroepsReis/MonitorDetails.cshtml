@model List<MonitorDeelneemerDetailsViewModel>
@{
    ViewData["Title"] = "Monitor details";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">Monitor details</h2>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    Er zijn nog geen Monitoren ingeschreven voor deze reis.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Naam</th>
                                <th>Voornaam</th>
                                <th>Leeftijd</th>
                                <th>Telefoon</th>
                                <th>Email</th>

                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var deelnemer in Model)
                            {
                                <tr>
                                    <td>@deelnemer.Naam</td>
                                    <td>@deelnemer.Voornaam</td>
                                    <td>@deelnemer.Leeftijd</td>
                                    <td>@deelnemer.Telefoon</td>
                                    <td>@deelnemer.Email</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
