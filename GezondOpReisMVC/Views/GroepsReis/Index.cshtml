@model GroepsReizenTonenViewModel
@{
    ViewData["Title"] = "Groepsreizen";
}
<div class="container position-relative">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Groepsreizen</h2>
  @if (User.Identity.IsAuthenticated && User.IsInRole("Beheerder")){
        <a href="@Url.Action("Create", "GroepsReis")" class="btn btn-primary shadow-sm" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; padding: 0;">+</a>
 }
    </div>
</div>


<div class="row mb-4">
    <!-- Zoekbalk -->
    <div class="col">
        <input id="searchInput" type="text" class="form-control" placeholder="Zoek reizen op naam..." ; box-shadow: 0 0 5px rgba(30, 144, 255, 0.5);" />
    </div>

    <!-- Leeftijdscategorie: Min en Max Leeftijd -->
    <div class="col">
        <div class="input-group">
            <input id="minAge" type="number" class="form-control" placeholder="Min leeftijd" min="0"/>
            <input id="maxAge" type="number" class="form-control" placeholder="Max leeftijd" min="0"/>
        </div>
    </div>

    <!-- Periode filter -->
    <div class="col">
        <div class="input-group">
        <input id="startDate" type="date" class="form-control"/>
        <input id="endDate" type="date" class="form-control">
        </div>
    </div>
</div>

<div id="groepsReizen" class="row g-4">
    @foreach (var item in Model.GroepsReizen)
    {
        <div class="col-md-6 col-lg-4 groepsReis"
             data-name="@item.Naam.ToLower()"
             data-minage="@item.MinLeeftijd"
             data-maxage="@item.MaxLeeftijd"
             data-start="@item.BeginDatum.ToString("yyyy-MM-dd")"
             data-end="@item.EindDatum.ToString("yyyy-MM-dd")">
            <div class="card h-100 shadow-sm border-0" >
                <img src="images/@item.Foto" class="card-img-top img-fluid rounded-top" alt="@item.Naam" />
                <div class="card-body">
                    <h5 class="card-title" >@item.Naam</h5>
                    <p class="card-text text-muted">
                        @item.Beschrijving
                    </p>
                    <ul class="list-unstyled mb-4">
                        <li><strong>Periode:</strong> @item.BeginDatum.ToShortDateString() - @item.EindDatum.ToShortDateString()</li>
                        <li><strong>Leeftijdscategorie:</strong> @item.MinLeeftijd - @item.MaxLeeftijd</li>
                        <li><strong>Prijs:</strong> €@item.Prijs.ToString("F2")</li>
                    </ul>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <a asp-action="ReisInfo" asp-route-id="@item.id" class="btn btn-primary">Meer Informatie</a>
                        </div>
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Beheerder"))
                        {
                            <div>
                                <a href="#" class="btn btn-danger" onclick="showDeleteModal(@item.id, '@item.Naam')">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 24 24" class="me-0">
                                        <path fill="currentColor" d="M7 21q-.825 0-1.412-.587T5 19V6H4V4h5V3h6v1h5v2h-1v13q0 .825-.587 1.413T17 21zm2-4h2V8H9zm4 0h2V8h-2z" />
                                    </svg>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Bevestig verwijdering</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Weet u zeker dat u de groepsreis "<span id="tripName"></span>" wilt verwijderen?</p>
                <p class="text-danger">Let op: Deze actie kan niet ongedaan worden gemaakt!</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                
                <a  id="dynamicDeleteButton" class="btn btn-danger">Verwijderen</a>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('input', filterReizen);
        document.getElementById('minAge').addEventListener('input', filterReizen);
        document.getElementById('maxAge').addEventListener('input', filterReizen);
        document.getElementById('startDate').addEventListener('change', filterReizen);
        document.getElementById('endDate').addEventListener('change', filterReizen);

        function filterReizen() {
            const query = document.getElementById('searchInput').value.toLowerCase();
            const minAgeInput = document.getElementById('minAge').value;
            const maxAgeInput = document.getElementById('maxAge').value;
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;
            const reizen = document.querySelectorAll('.groepsReis');

            // Parse min and max age inputs
            const minAge = minAgeInput ? parseInt(minAgeInput, 10) : null;
            const maxAge = maxAgeInput ? parseInt(maxAgeInput, 10) : null;

            reizen.forEach(reis => {
                const name = reis.getAttribute('data-name');
                const reisMinAge = parseInt(reis.getAttribute('data-minage'), 10);
                const reisMaxAge = parseInt(reis.getAttribute('data-maxage'), 10);
                const reisStart = reis.getAttribute('data-start');
                const reisEnd = reis.getAttribute('data-end');

                // Check name query
                const matchesQuery = name.includes(query);

                // Check age range
                let matchesAge = true;
                if (minAge !== null && reisMinAge < minAge) {
                    matchesAge = false;
                }
                if (maxAge !== null && reisMaxAge > maxAge) {
                    matchesAge = false;
                }

                // Check date range
                const matchesPeriod = (!startDate || reisStart >= startDate) && (!endDate || reisEnd >= endDate);

                if (matchesQuery && matchesAge && matchesPeriod) {
                    reis.style.display = 'block';
                } else {
                    reis.style.display = 'none';
                }
            });
        }

        // Delete modal functionality
        let deleteId = null;
        const modal = new bootstrap.Modal(document.getElementById('deleteModal'));

        function showDeleteModal(id, name) {
            deleteId = id;
            document.getElementById('tripName').textContent = name;

            const deleteButton = document.getElementById('dynamicDeleteButton');
            deleteButton.setAttribute('href', `/GroepsReis/DeleteConfirmed/${deleteId}`);
            modal.show();
            
        }

    </script>
}
