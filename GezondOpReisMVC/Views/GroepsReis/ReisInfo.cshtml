@model GroepsReisInfoViewModel
@inject UserManager<CustomUser> UserManager
@{
    ViewData["Title"] = "Groepsreizen";

}
<h2 class="text-center mb-4">@Model.Naam</h2>

<div class="container">
    <div class="row">
        <div class="col-md-12 mb-4">
            <div id="reisCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.Fotos.Count; i++)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <img src="/images/@Model.Fotos[i]" class="d-block w-100 rounded" alt="@Model.Naam foto @(i + 1)" style="object-fit: cover; height: 400px;" />
                        </div>
                    }
                </div>
                @if (Model.Fotos.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#reisCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#reisCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h4 class="card-title">Over deze reis</h4>
                    <p class="card-text text-muted">
                        @Model.Beschrijving
                    </p>
                    <hr />
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-calendar-event me-2"></i> @Model.BeginDatum.ToShortDateString() - @Model.EindDatum.ToShortDateString()</li>
                                <li class="mb-2"><i class="bi bi-people me-2"></i> @Model.MinLeeftijd - @Model.MaxLeeftijd jaar</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-currency-euro me-2"></i><strong>Prijs:</strong> €@Model.Prijs.ToString("F2")</li>
                                <li class="mb-2"><i class="bi bi-person-check me-2"></i><strong>Aantal Deelnemers:</strong> @(Model.Deelnemers?.Count ?? 0)</li>
                            </ul>
                        </div>
                    </div>
                  
                    
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h4 class="card-title">Monitoren</h4>
                    <div class="list-group list-group-flush">
                        @if (Model.Monitoren != null && Model.Monitoren.Any())
                        {
                            foreach (var monitor in Model.Monitoren)
                            {
                                <div class="list-group-item border-0">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0">@monitor.Persoon.Voornaam @monitor.Persoon.Naam</h6>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted mb-0">Geen monitoren toegewezen</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    @if (Model.Deelnemers != null && Model.Deelnemers.Any() && User.Identity.IsAuthenticated)
    {
        
        <div class="row mt-4">
            <div class="col-md-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h4 class="card-title">Ingeschreven Kinderen</h4>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Naam</th>
                                        <th>Voornaam</th>
                                        <th>Acties</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var deelnemer in Model.Deelnemers)
                                    {
                                        @if (User.Identity.Name == deelnemer.Kind.CustomUser.UserName)
                                        {
                                            
                                        <tr>
                                            <td>@deelnemer.Kind.Naam</td>
                                            <td>@deelnemer.Kind.Voornaam</td>
                                            <td>
                                                <form asp-action="UitschrijvenVanReis" method="post" style="display: inline;">
                                                    <input type="hidden" name="kindId" value="@deelnemer.Kind.Id" />
                                                    <input type="hidden" name="reisId" value="@Model.Id" />
                                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Weet je zeker dat je dit kind wilt uitschrijven?');">
                                                        <i class="bi bi-person-dash"></i> Uitschrijven
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (TempData["AlertMessage"] != null)
    {
        <div class="alert alert-success mt-4" role="alert">
            @TempData["AlertMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mt-4" role="alert">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="row mt-4">
        <div class="col-md-12 text-center">
            <div class="d-flex justify-content-center gap-3">
 
                <button type="button" class="btn btn-primary" onclick="openInschrijvenModal(@Model.Id)">
                    <i class="bi bi-person-plus me-2"></i> Kind inschrijven
                </button>
                @if (User.Identity.IsAuthenticated && User.IsInRole("Monitor"))
                {
                    <a asp-action="MonitorInschrijvenOpReis" asp-route-groepsReisId="@Model.Id" asp-route-persoonId="@UserManager.GetUserId(User)" class="btn btn-success">
                        <i class="bi bi-person-badge me-2"></i>Inschrijven als Monitor
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        function openInschrijvenModal(reisId) {
            $.get('@Url.Action("GetInschrijvenModal")', { id: reisId }, function(response) {
                if (response.redirect) {
                    window.location.href = response.redirect;
                } else {
                    $('#modalContainer').html(response);
                    $('#inschrijvenModal').modal('show');
                }
            }).fail(function() {
                alert('Er is een fout opgetreden bij het laden van het formulier.');
            });
        }
    </script>
}
