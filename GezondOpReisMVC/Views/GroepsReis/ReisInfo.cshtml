@model GroepsReisInfoViewModel
@{
    ViewData["Title"] = "Groepsreizen";
    Console.WriteLine(Model.Fotos);
    Console.WriteLine("Tets");
}
<h2 class="text-center mb-4">@Model.Naam</h2>

<div class="container">
    <div class="row">
        <div class="col-md-12 mb-4">
            <div id="reisCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.Fotos.Count; i++)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <img src="/images/@Model.Fotos[i]" class="d-block w-100 rounded" alt="@Model.Naam foto @(i + 1)" style="object-fit: cover; height: 400px;" />
                        </div>
                    }
                </div>
                @if (Model.Fotos.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#reisCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#reisCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">@Model.Naam</h5>
                    <p class="card-text text-muted">
                        @Model.Beschrijving
                    </p>
                    <ul class="list-unstyled mb-4">
                        <li><strong>Periode:</strong> @Model.BeginDatum.ToShortDateString() - @Model.EindDatum.ToShortDateString()</li>
                        <li><strong>Leeftijdscategorie:</strong> @Model.MinLeeftijd - @Model.MaxLeeftijd</li>
                        <li><strong>Prijs:</strong> €@Model.Prijs.ToString("F2")</li>
                    </ul>
@*                     @foreach (var a in Model.Activiteiten)
                    {
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">@a.Naam</h5>
                                <p class="card-text">@a.Beschrijving</p>
                            </div>
                        </div>
                    } *@
                </div>
            </div>
        </div>
    </div>
</div>
