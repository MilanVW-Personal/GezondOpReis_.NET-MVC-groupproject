@model GroepsReisInfoViewModel
@inject UserManager<CustomUser> UserManager
@{
    ViewData["Title"] = "Groepsreizen";

}
@if(User.IsInRole("Beheerder") || User.IsInRole("Verantwoordelijke"))
{
    <div class="container position-relative">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">@Model.Naam</h2>
            <a asp-action="Index" asp-route-id="@Model.Id" class="btn btn-primary me-2" asp-controller="Onkosten">
                Onkosten beheren
            </a>
        </div>
    </div>
}
else
{
    <h2 class="text-center mb-4">@Model.Naam</h2>
}


<div class="container">
    <div class="row">
        <div class="col-md-12 mb-4">
            <div id="reisCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.Fotos.Count; i++)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <img src="/images/@Model.Fotos[i]" class="d-block w-100 rounded" alt="@Model.Naam foto @(i + 1)" style="object-fit: cover; height: 400px;" />
                        </div>
                    }
                </div>
                @if (Model.Fotos.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#reisCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#reisCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="card-title me-auto">Over deze reis</h4>
                        @if (User.IsInRole("Ouder"))
                        {

                        <button type="button" class="btn btn-primary ms-3" onclick="openInschrijvenModal(@Model.Id)">
                            <i class="bi bi-person-plus me-2"></i> Kind inschrijven
                        </button>
                        }
                    </div>
                    <p class="card-text text-muted">
                        @Model.Beschrijving
                    </p>

                    <hr />
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-calendar-event me-2"></i> @Model.BeginDatum.ToShortDateString() - @Model.EindDatum.ToShortDateString()</li>
                                <li class="mb-2"><i class="bi bi-people me-2"></i> @Model.MinLeeftijd - @Model.MaxLeeftijd jaar</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-currency-euro me-2"></i><strong>Prijs:</strong> €@Model.Prijs.ToString("F2")</li>
                                <li class="mb-2"><i class="bi bi-person-check me-2"></i><strong>Aantal deelnemers:</strong> @(Model.Deelnemers?.Count ?? 0)</li>
                            </ul>
                        </div>
                    </div>
                  
                    
                </div>
            </div>
        </div>
        @if (User.IsInRole("Monitor"))
        {

        <div class="col">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h4 class="card-title">Monitoren</h4>
                    <div class="list-group list-group-flush">
                        @if (Model.Monitoren != null && Model.Monitoren.Any())
                        {
                            var currentUserIsHoofdMonitor = Model.Monitoren.Any(m => m.PersoonId == UserManager.GetUserId(User) && m.isHoofdMonitor == true);
                            
                            @if (currentUserIsHoofdMonitor)
                            {
                                <div class="mb-3">
                                    <a asp-action="DeelnemerDetails" asp-route-reisId="@Model.Id" class="btn btn-primary w-100">
                                        <i class="bi bi-list-ul me-2"></i>Bekijk Deelnemer Details
                                    </a>
                                </div>
                                <div class="mb-3">
                                        <a asp-action="MonitorDetails" asp-route-reisId="@Model.Id" class="btn btn-primary w-100">
                                        <i class="bi bi-list-ul me-2"></i>Bekijk Monitor Details
                                    </a>
                                </div>
                            }

                            foreach (var monitor in Model.Monitoren)
                            {
                                <div class="list-group-item border-0">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0">@monitor.Persoon.Voornaam @monitor.Persoon.Naam</h6>
                                            @if (monitor.isHoofdMonitor == true)
                                            {
                                                <small class="text-primary">Hoofdmonitor</small>
                                            }
                                        </div>
                                        @if (UserManager.GetUserId(User) == monitor.PersoonId)
                                        {
                                            <a asp-action="MonitorUitschrijvenVanReis" asp-route-monitorId="@monitor.PersoonId" asp-route-reisId="@Model.Id" class="btn btn-sm btn-outline-danger">Uitschrijven</a>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted mb-0">Geen monitoren toegewezen</p>
                        }
                    </div>
                    @if (User.IsInRole("Monitor") && !Model.Monitoren.Any(m => m.PersoonId == UserManager.GetUserId(User)))
                    {
                        var hasHoofdMonitor = Model.Monitoren != null && Model.Monitoren.Any(m => m.isHoofdMonitor == true);
                        <div class="mt-3">
                            <form asp-action="MonitorInschrijvenOpReis" method="post" class="d-flex flex-column gap-2">
                                <input type="hidden" name="persoonId" value="@UserManager.GetUserId(User)" />
                                <input type="hidden" name="groepsReisId" value="@Model.Id" />



                                    @if (!hasHoofdMonitor && UserManager.FindByNameAsync(User.Identity.Name).Result.IsHoofdMonitor == true)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="isHoofdMonitor" id="isHoofdMonitor" value="true">
                                        <label class="form-check-label" for="isHoofdMonitor">
                                            Inschrijven als hoofdmonitor
                                        </label>
                                    </div>
                                }
                                <button type="submit" class="btn btn-primary">Inschrijven als monitor</button>
                            </form>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger mt-3">
                            @TempData["ErrorMessage"]
                        </div>
                    }
                    @if (TempData["AlertMessage"] != null)
                    {
                        <div class="alert alert-success mt-3">
                            @TempData["AlertMessage"]
                        </div>
                    }
                </div>
            </div>
        </div>
        }
    </div>
    @if (User.Identity.IsAuthenticated)
    {
        @if (Model.Deelnemers != null && Model.Deelnemers.Any(d => d.Kind?.CustomUser?.UserName == User.Identity.Name))
        {

            <div class="row mt-4">
                <div class="col-md-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <h4 class="card-title">Ingeschreven Kinderen</h4>
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Naam</th>
                                            <th>Voornaam</th>
                                            <th>Acties</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var deelnemer in Model.Deelnemers)
                                        {

                                            @if (User.Identity.Name == deelnemer.Kind.CustomUser.UserName)
                                            {

                                                <tr>
                                                    <td>@deelnemer.Kind.Naam</td>
                                                    <td>@deelnemer.Kind.Voornaam</td>
                                                    <td>
                                                        <form asp-action="UitschrijvenVanReis" method="post" style="display: inline;">
                                                            <input type="hidden" name="kindId" value="@deelnemer.Kind.Id" />
                                                            <input type="hidden" name="reisId" value="@Model.Id" />
                                                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Weet je zeker dat je dit kind wilt uitschrijven?');">
                                                                <i class="bi bi-person-dash"></i> Uitschrijven
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

    }


        <div class="row mt-4">
            <div class="col-md-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h4 class="card-title">Reviews voor deze reis</h4>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Gebruiker</th>
                                        <th>Commentaar</th>
                                        <th>Aantal sterren</th>
                                    @if (User.IsInRole("Beheerder"))  // Verantwoordelijke moet hierbij
                                        {
                                            <th>Acties</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                @if(Model.Reviews.Count == 0)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center m-2">Er zijn geen reviews voor deze reis!</td>
                                    </tr>
                                }
                                @foreach (var review in Model.Reviews)
                                {
                                    <tr>
                                        <td>@review.Persoon.UserName</td>
                                        <td>@review.Tekst</td>
                                        <td>@review.Score</td>
                                        @if (User.IsInRole("Beheerder") || User.IsInRole("Verantwoordelijke")) // Verantwoordelijke moet hierbij
                                        {
                                            <td>
                                                <form asp-action="DeleteReview" asp-controller="Review" asp-route-id="@review.Id" method="post">
                                                    <button type="submit" class="btn btn-danger">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                                            <path fill="currentColor" d="M7 21q-.825 0-1.412-.587T5 19V6H4V4h5V3h6v1h5v2h-1v13q0 .825-.587 1.413T17 21zm2-4h2V8H9zm4 0h2V8h-2z" />
                                                        </svg>
                                                    </button>
                                                </form>
                                            </td>
                                        }
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    

</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        function openInschrijvenModal(reisId) {
            $.get('@Url.Action("GetInschrijvenModal")', { id: reisId }, function(response) {
                if (response.redirect) {
                    window.location.href = response.redirect;
                } else {
                    $('#modalContainer').html(response);
                    $('#inschrijvenModal').modal('show');
                }
            }).fail(function() {
                alert('Er is een fout opgetreden bij het laden van het formulier.');
            });
        }
    </script>
}
