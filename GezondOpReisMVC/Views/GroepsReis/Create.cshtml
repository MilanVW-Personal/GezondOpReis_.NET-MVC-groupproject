@model GroepsReisCreateViewModel

@{
    ViewData["Title"] = "Nieuwe Groepsreis";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h2 class="card-title text-center mb-4">Nieuwe Groepsreis</h2>
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="BestemmingId" class="form-label"></label>
                            <select asp-for="BestemmingId" class="form-select" 
                                    asp-items="@(new SelectList(Model.Bestemmingen, "Id", "Naam"))">
                                <option value="">Selecteer een bestemming</option>
                            </select>
                            <span asp-validation-for="BestemmingId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="BeginDatum" class="form-label"></label>
                            <input asp-for="BeginDatum" class="form-control" type="date" />
                            <span asp-validation-for="BeginDatum" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EindDatum" class="form-label"></label>
                            <input asp-for="EindDatum" class="form-control" type="date" />
                            <span asp-validation-for="EindDatum" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Prijs" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">€</span>
                                <input asp-for="Prijs" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="Prijs" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Aanmaken</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Terug naar overzicht</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Add client-side validation for end date being after start date
        $(document).ready(function () {
            $('form').submit(function (e) {
                var startDate = new Date($('#BeginDatum').val());
                var endDate = new Date($('#EindDatum').val());
                
                if (endDate < startDate) {
                    e.preventDefault();
                    alert('De einddatum moet na de begindatum liggen.');
                }
            });
        });
    </script>
}
