@model List<DeelnemerDetailsViewModel>
@{
    ViewData["Title"] = "Deelnemer Details";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    Er zijn nog geen deelnemers ingeschreven voor deze reis.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Naam</th>
                                <th>Voornaam</th>
                                <th>Leeftijd</th>
                                <th>Telefoon Ouder</th>
                                <th>Medicatie</th>
                                <th>Allergieën</th>
                                <th>Opmerkingen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var deelnemer in Model)
                            {
                                <tr>
                                    <td>@deelnemer.Naam</td>
                                    <td>@deelnemer.Voornaam</td>
                                    <td>@deelnemer.Leeftijd</td>
                                    <td>@deelnemer.OuderTelefoon</td>
                                    <td>@deelnemer.Medicatie</td>
                                    <td>@deelnemer.Allergieen</td>
                                    <td>@deelnemer.Opmerkingen</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
