@model Bestemming

<h4>Gebruik onderstaand formulier om een nieuwe bestemming aan te maken</h4>
<div>
    <form asp-action="Create" enctype="multipart/form-data" onsubmit="return ageValidation()">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group">
            <label asp-for="Naam" class="control-label"></label>
            <input asp-for="Naam" class="form-control" />
            <span asp-validation-for="Naam" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Beschrijving" class="control-label"></label>
            <input asp-for="Beschrijving" class="form-control" />
            <span asp-validation-for="Beschrijving" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Code" class="control-label"></label>
            <input asp-for="Code" class="form-control" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="MinLeeftijd" class="control-label"></label>
            <input asp-for="MinLeeftijd" class="form-control" id="minLeeftijd"/>
            <span asp-validation-for="MinLeeftijd" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="MaxLeeftijd" class="control-label"></label>
            <input asp-for="MaxLeeftijd" class="form-control" id="maxLeeftijd" />
            <span asp-validation-for="MaxLeeftijd" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label class="control-label">Foto</label>
            <input class="form-control" type="file" name="fotoFiles" multiple/>
        </div>
       
        <div class="form-group mt-2">
            <input type="submit" value="Bestemming aanmaken" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-primary">Terug naar overzicht</a>
        </div>
    </form>
</div>
  

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const ageValidation = () => {
            let minLeeftijd = document.querySelector("#minLeeftijd")
            let maxLeeftijd = document.querySelector("#maxLeeftijd")

            if (parseInt(minLeeftijd.value) > parseInt(maxLeeftijd.value)) {
                alert("De minimum leeftijd kan niet groter zijn dan de maximum leeftijd!")
                return false;
            }

            return true;
        }
    </script>
}
