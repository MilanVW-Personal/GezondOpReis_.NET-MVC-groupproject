@model GezondOpReis.ViewModels.GebruikerCreateViewModel

@{
    ViewData["Title"] = "Maak account";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="col-md-8">
        <div class="card shadow-lg">
            <h2 class="text-center mt-3">Maak account</h2>
            <div class="card-body p-4">
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <p><span>* (verplichte velden!)</span></p>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Email" class="form-control" autocomplete="username" aria-required="true" placeholder="E-mail" />
                                <label asp-for="Email" class="form-label">E-mail <span class="text-danger">*</span></label>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Passwoord" type="password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Wachtwoord" />
                                <label asp-for="Passwoord" class="form-label">Wachtwoord <span class="text-danger">*</span></label>
                                <span asp-validation-for="Passwoord" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Naam" class="form-control" autocomplete="name" aria-required="true" placeholder="Naam" />
                                <label asp-for="Naam" class="form-label">Naam <span class="text-danger">*</span></label>
                                <span asp-validation-for="Naam" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Voornaam" class="form-control" autocomplete="given-name" aria-required="true" placeholder="Voornaam" />
                                <label asp-for="Voornaam" class="form-label">Voornaam <span class="text-danger">*</span></label>
                                <span asp-validation-for="Voornaam" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Straat" class="form-control" placeholder="Straat" aria-required="true" />
                                <label asp-for="Straat" class="form-label">Straat <span class="text-danger">*</span></label>
                                <span asp-validation-for="Straat" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Huisnummer" class="form-control" placeholder="Huisnummer" aria-required="true" />
                                <label asp-for="Huisnummer" class="form-label">Huisnummer <span class="text-danger">*</span></label>
                                <span asp-validation-for="Huisnummer" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Gemeente" class="form-control" placeholder="Gemeente" aria-required="true" />
                                <label asp-for="Gemeente" class="form-label">Gemeente <span class="text-danger">*</span></label>
                                <span asp-validation-for="Gemeente" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Postcode" class="form-control" placeholder="Postcode" aria-required="true" />
                                <label asp-for="Postcode" class="form-label">Postcode <span class="text-danger">*</span></label>
                                <span asp-validation-for="Postcode" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="GeboorteDatum" class="form-control" type="date" placeholder="Geboortedatum" aria-required="true" />
                                <label asp-for="GeboorteDatum" class="form-label">Geboortedatum <span class="text-danger">*</span></label>
                                <span asp-validation-for="GeboorteDatum" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Huisdokter" class="form-control" placeholder="Huisdokter" aria-required="true" />
                                <label asp-for="Huisdokter" class="form-label">Huisdokter <span class="text-danger">*</span></label>
                                <span asp-validation-for="Huisdokter" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="TelefoonNummer" class="form-control" placeholder="Telefoonnummer" aria-required="true" />
                                <label asp-for="TelefoonNummer" class="form-label">Telefoonnummer <span class="text-danger">*</span></label>
                                <span asp-validation-for="TelefoonNummer" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="ContactNummer" class="form-control" placeholder="Contactnummer" />
                                <label asp-for="ContactNummer" class="form-label">Contactnummer</label>
                                <span asp-validation-for="ContactNummer" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="RekeningNummer" class="form-control" placeholder="Rekeningnummer" />
                                <label asp-for="RekeningNummer" class="form-label">Rekeningnummer</label>
                                <span asp-validation-for="RekeningNummer" class="text-danger"></span>
                            </div>

                            <div class="form-check mb-3">
                                <input asp-for="IsOuder" class="form-check-input" />
                                <label asp-for="IsOuder" class="form-check-label">Account als Ouder aanmaken</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button id="register-submit" type="submit" class="btn btn-primary">Maak account</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>