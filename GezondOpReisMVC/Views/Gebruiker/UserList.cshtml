@model IEnumerable<GezondOpReis.Models.CustomUser>

@{
    ViewData["Title"] = "Gebruikerslijst";
}

<h1>Gebruikerslijst</h1>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Voornaam)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Naam)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GeboorteDatum)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TelefoonNummer)
            </th>
            <th>
                Acties
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => user.Voornaam)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => user.Naam)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => user.Email)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => user.GeboorteDatum)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => user.TelefoonNummer)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id">Bewerken</a> |
                    <a asp-action="Details" asp-route-id="@user.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@user.Id">Verwijderen</a>
                </td>
            </tr>
        }
    </tbody>
</table>