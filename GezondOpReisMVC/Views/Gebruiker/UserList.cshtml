@using GezondOpReis.ViewModels
@model UserListViewModel
@inject UserManager<GezondOpReis.Models.CustomUser> UserManager

@{
    ViewData["Title"] = "Gebruikerslijst";
}

<div class="text-center">
    <h1>Gebruikerslijst</h1>
</div>

<div>
    @if (TempData["AlertMessage"] != null)
    {
        <div class="alert alert-success" role="alert">
            <b>@TempData["AlertMessage"]</b>
        </div>
    }

    <form asp-action="UserList" method="get" id="userListForm">
        <div class="form-row row mb-3">
            <div class="form-group col">
                <div class="position-relative">
                    <select asp-for="SelectedRole" asp-items="Model.Roles" class="form-control" onchange="this.form.submit()">
                        
                    </select>
                    <span class="position-absolute end-0 top-50 translate-middle-y me-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M7 10l5 5 5-5z" />
                        </svg>
                    </span>
                </div>
            </div>
            <div class="form-group col">
                <input id="searchInput" type="text" class="form-control" placeholder="Zoek gebruikers op naam...">
            </div>
        </div>
    </form>

    <div id="userListContainer">
        @foreach (var user in Model.Users)
        {
            var roles = await UserManager.GetRolesAsync(user);
            <div class="card mb-3 user-card" data-name="@user.Voornaam @user.Naam">
                <div class="card-body position-relative">
                    <div class="card-buttons position-absolute top-0 end-0 me-2 mt-2">
                        <a asp-action="UserEdit" asp-route-id="@user.Id" class="btn btn-primary me-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                <path fill="currentColor" d="M5 19h1.425L16.2 9.225L14.775 7.8L5 17.575zm-2 2v-4.25L16.2 3.575q.3-.275.663-.425t.762-.15t.775.15t.65.45L20.425 5q.3.275.438.65T21 6.4q0 .4-.137.763t-.438.662L7.25 21zM19 6.4L17.6 5zm-3.525 2.125l-.7-.725L16.2 9.225z" />
                            </svg>
                        </a>
                        <a asp-action="UserDetails" asp-route-id="@user.Id" class="btn btn-secondary me-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                <path fill="currentColor" d="M12 12c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm0-2c-1.7 0-3 1.3-3 3s1.3 3 3 3 3-1.3 3-3-1.3-3-3-3zm0-2c2.2 0 4 1.8 4 4s-1.8 4-4 4-4-1.8-4-4 1.8-4 4-4z" />
                            </svg>
                        </a>
                        @if (!user.Email.Equals("admin@gmail.com"))
                        {
                            <a asp-action="UserDelete" asp-route-id="@user.Id" class="btn btn-danger">
                                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                    <path fill="currentColor" d="M7 21q-.825 0-1.412-.587T5 19V6H4V4h5V3h6v1h5v2h-1v13q0 .825-.587 1.413T17 21zm2-4h2V8H9zm4 0h2V8h-2z" />
                                </svg>
                            </a>
                        }
                        
                    </div>
                    <h5 class="card-title">@Html.DisplayFor(modelItem => user.Voornaam) @Html.DisplayFor(modelItem => user.Naam)</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <p class="card-text"><b>Email:</b> @Html.DisplayFor(modelItem => user.Email)</p>
                            <p class="card-text"><b>GeboorteDatum:</b> @(user.GeboorteDatum.ToString("dd-MM-yyyy"))</p>
                        </div>
                        <div class="col-md-6">
                            <p class="card-text"><b>Telefoonnummer:</b> @Html.DisplayFor(modelItem => user.TelefoonNummer)</p>
                            <p class="card-text"><b>Rol:</b> @string.Join(", ", roles)</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .card-text {
        margin-bottom: 0.5rem;
    }

    .card-buttons {
        z-index: 1;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("searchInput");
        const userCards = document.querySelectorAll(".user-card");

        searchInput.addEventListener("input", function () {
            const filter = searchInput.value.toLowerCase();

            userCards.forEach(card => {
                const userName = card.getAttribute("data-name").toLowerCase();
                if (userName.includes(filter)) {
                    card.style.display = "block";
                } else {
                    card.style.display = "none";
                }
            });
        });
    });
</script>