@{
    ViewData["Title"] = "Delete kind";
}

@model KindDeleteViewModel

<h1>Delete</h1>
<div>
    <h4>Bent u zeker dat u @Model.Voornaam @Model.Naam wilt verwijderen?</h4>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-primary" />
        <a asp-action="Index" asp-route-id="@User.FindFirstValue(ClaimTypes.NameIdentifier)" class="btn btn-primary">Terug naar overzicht</a>
    </form>
</div>
