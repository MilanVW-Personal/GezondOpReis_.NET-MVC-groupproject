    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model List<KindViewModel>

<div class="d-flex justify-content-between align-items mb-4">
    <h2 class="mb-0">Kinderen van @User.Identity.Name</h2>
    <a asp-action="Create" class="btn btn-primary" style="margin-top: auto; margin-bottom: auto;">
        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="M11 21v-8H3v-2h8V3h2v8h8v2h-8v8z" /></svg>
    </a>
</div>

@if (TempData["AlertMessage"] != null)
{
    <div class="alert alert-success" role="alert">
        <b>@TempData["AlertMessage"]</b>
    </div>
}


<div>
    <table class="table">
        <thead>
            <tr>
                <th>Naam</th>
                <th>Voornaam</th>
                <th>Geboortedatum</th>
                <th>Allergieën</th>
                <th>Medicatie</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var kind in Model)
            {
                <tr>
                    <td>@kind.Naam</td>
                    <td>@kind.Voornaam</td>
                    <td>@kind.GeboorteDatum.ToString("yyyy-MM-dd")</td>
                    <td>@kind.Allergieen</td>
                    <td>@kind.Medicatie</td>
                    <td>
                        <a asp-action="Edit" class="btn btn-primary" asp-route-id="@kind.Id">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                <path fill="currentColor" d="M5 19h1.425L16.2 9.225L14.775 7.8L5 17.575zm-2 2v-4.25L16.2 3.575q.3-.275.663-.425t.762-.15t.775.15t.65.45L20.425 5q.3.275.438.65T21 6.4q0 .4-.137.763t-.438.662L7.25 21zM19 6.4L17.6 5zm-3.525 2.125l-.7-.725L16.2 9.225z" />
                            </svg>
                        </a>

                        <a asp-action="Delete" class="btn btn-danger" asp-route-id="@kind.Id">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                <path fill="currentColor" d="M7 21q-.825 0-1.412-.587T5 19V6H4V4h5V3h6v1h5v2h-1v13q0 .825-.587 1.413T17 21zm2-4h2V8H9zm4 0h2V8h-2z" />
                            </svg>
                        </a>
                    </td> 
                </tr>
            }
        </tbody>
    </table>
</div>
