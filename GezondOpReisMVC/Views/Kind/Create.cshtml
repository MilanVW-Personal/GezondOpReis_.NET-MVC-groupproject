@{
}
@model KindCreateViewModel

<h4>Gebruik onderstaand formulier om een nieuw kind toe te voegen</h4>
<div>
    <form asp-action="Create" enctype="multipart/form-data" onsubmit="return validateForm()">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group">
            <label asp-for="Naam" class="control-label"></label>
            <input asp-for="Naam" class="form-control" />
            <span asp-validation-for="Naam" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Voornaam" class="control-label"></label>
            <input asp-for="Voornaam" class="form-control" />
            <span asp-validation-for="Voornaam" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="GeboorteDatum" class="control-label"></label>
            <input asp-for="GeboorteDatum" class="form-control" />
            <span asp-validation-for="GeboorteDatum" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Allergieen" class="control-label"></label>
            <input asp-for="Allergieen" class="form-control" id="allergieen"/>
            <span asp-validation-for="Allergieen" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Medicatie" class="control-label"></label>
            <input asp-for="Medicatie" class="form-control" id="medicatie"/>
            <span asp-validation-for="Medicatie" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <input type="submit" value="Kind toevoegen" class="btn btn-primary" />
            <a asp-action="Index" asp-route-id="@User.FindFirstValue(ClaimTypes.NameIdentifier)" class="btn btn-primary">Terug naar overzicht</a>
        </div>
    </form>
</div>
  

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");

        <script>

            function validateForm() {
                let medicatie = document.getElementById("medicatie");
                let allergieen = document.getElementById("allergieen");

                if (medicatie.value.trim() === "") {
                    medicatie.value = "Geen";
                }

                if (allergieen.value.trim() === "") {
                    allergieen.value = "Geen";
                }

                return true; 
            }

        </script>

        
    }
    
}
