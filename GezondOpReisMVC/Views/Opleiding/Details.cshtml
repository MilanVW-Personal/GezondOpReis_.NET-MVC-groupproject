@using GezondOpReis.ViewModels
@model OpleidingDetailsViewModel

@{
    ViewData["Title"] = "Opleiding Details";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<h1>Opleiding Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Naam)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Naam)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Beschrijving)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Beschrijving)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.StartDatum)
        </dt>
        <dd class="col-sm-10">
            @(Model.StartDatum.ToString("dd-MM-yyyy"))
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EindDatum)
        </dt>
        <dd class="col-sm-10">
            @(Model.EindDatum.ToString("dd-MM-yyyy"))
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.AantalPlaatsen)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AantalPlaatsen)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Bewerken</a> |
    <a asp-action="Index" class="btn btn-secondary">Terug naar lijst</a>
</div>